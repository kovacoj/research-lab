{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "siemens": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "code.siemens.com",
            "options": {
                "baseURL": "https://api.siemens.com/llm/v1",
                "apiKey": "{env:SIEMENS_LLM_API_KEY}"
            },
            "models": {
                "glm-5": {
                    "limit": {
                        "context": 202752,
                        "output": 202752
                    }
                },
                "qwen-3.6-27b": {
                    "limit": {
                        "context": 262144,
                        "output": 262144
                    },
                    "modalities": {
                        "input": [
                            "text",
                            "image"
                        ],
                        "output": [
                            "text"
                        ]
                    }
                },
                "ministral-3-14b-instruct-2512": {
                    "limit": {
                        "context": 256000,
                        "output": 256000
                    },
                    "modalities": {
                        "input": [
                            "text",
                            "image"
                        ],
                        "output": [
                            "text"
                        ]
                    }
                }
            }
        }
    },
    "share": "disabled"
}
